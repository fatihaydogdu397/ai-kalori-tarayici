platform :ios, '15.5'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
  end
  # Fix: Xcode build phase cycle (Thin Binary + Embed Pods Frameworks)
  installer.aggregate_targets.each do |aggregate_target|
    aggregate_target.user_project.targets.each do |target|
      target.build_phases.each do |build_phase|
        if build_phase.respond_to?(:name) && build_phase.name == 'Thin Binary'
          build_phase.input_paths = []
          build_phase.output_paths = []
        end
      end
    end
    aggregate_target.user_project.save
  end
  # Fix: Inject Flutter xcconfig into Pods-Runner xcconfig files so that
  # both Pod AND Flutter build settings are active when Pods xcconfig is
  # used as the baseConfigurationReference (resolves "Pods_Runner not found")
  pods_xcconfig_dir = "#{installer.sandbox.root}/Target Support Files/Pods-Runner"
  {
    'Pods-Runner.debug.xcconfig'   => '#include "../../../Flutter/Debug.xcconfig"',
    'Pods-Runner.release.xcconfig' => '#include "../../../Flutter/Release.xcconfig"',
    'Pods-Runner.profile.xcconfig' => '#include "../../../Flutter/Release.xcconfig"',
  }.each do |filename, include_line|
    xcconfig_path = File.join(pods_xcconfig_dir, filename)
    if File.exist?(xcconfig_path)
      content = File.read(xcconfig_path)
      unless content.include?(include_line)
        File.write(xcconfig_path, "#{include_line}\n#{content}")
        puts "Injected Flutter xcconfig into #{filename}"
      end
    end
  end
end
